// Variável para o arquivo da biblioteca
def lib

// Variáveis para os objetos JSON
Map jsonConf // Parâmetros de configuração
Map jsonData // Informações dos bancos de dados
Map jsonPlan // Planejamento do revert

// Variável para os dados do database
Map database = [
    descricao  : '',
    enderecoIP : '',
    porta      : '',
    serviceName: '',
    conexao    : ''
]

// Variável com as ações configuradas no planejamento
/*Map acao = [
    matarSessoes     : false,
    listarInvalidos  : false,
    recompilarObjetos: false
]
*/

Map acao = [
    matarSessoes     : [
        executar: false,
        script  : ''
    ],
    listarInvalidos  : [
        executar: false,
        script  : ''
    ],
    recompilarObjetos: [
        executar: false,
        script  : ''
    ]
]

// Variável para armazenar o diretório raiz do repositório
String diretorioRaiz = ''

// Variável para display de texto em bloco
List<String> texto = []


pipeline {
    agent any
    environment {
        // Credencial de conexão com o banco de dados
        DB_CONN = credentials('DevOps_DB')
    }

    options {
        // Altera o funcionamento default e não faz o checkout do SCM no início do build
        skipDefaultCheckout(true)
    }

    stages {

        stage('Limpa Workspace') {
            steps {
                script {
                    echo 'Limpando Workspace antes do checkout'
                    cleanWs() // Limpa resíduos de builds antigos
                } //Script 
            } // Steps
        } // Stage 'Preparação'


        stage('Checkout Repositório') {
            steps {
                script {
                    echo 'Realizando Checkout do Repositório'

                    // Verifica se o parâmetro Tag foi selecionado
                    if (Tag == 'None') {
                        error 'É necessário selecionar uma Tag para o checkout do repositório e revert!'
                    }

                    echo "Realizando checkout da Tag: ${Tag}"
                    checkout scm: ([
                        $class: 'GitSCM',
                        branches: [[name: Tag]],
                        userRemoteConfigs: scm.userRemoteConfigs,
                        extensions: scm.extensions
                    ])
                    echo 'Checkout do Repositório Concluído'
                } // script
            } // Steps
        } // stage 'Checkout Repositório'


        stage('Inicia Processo') {
            steps {
                script {
                    echo 'Início do Processo'

                    echo 'Carrega a biblioteca'
                    try {
                        lib = load 'Config/Jenkins/LibraryFile'
                    } catch (Exception e) {
                        // Erro crítico: coloca na console e aborta
                        echo "Falha carregando a biblioteca (Config/Jenkins/LibraryFile):\n${e.getMessage()}"
                        error "Falha carregando a biblioteca"
                    }

                    // Nome do arquivo de config
                    String confFile = 'Config/Jenkins/ConfigParam.json'
                    echo "Processa arquivo JSON de parâmetros de configuração: ${confFile}"

                    // Verifica se o arquivo JSON existe, se está válido e com dados
                    try {
                        jsonConf = lib.parseJSON(confFile, 'dos parâmetros de configuração')

                    //} catch (hudson.AbortException e) {
                    //    throw e
                    } catch (Exception e) {
                        //echo "Erro: ${e.getMessage()}"
                        echo lib.status('E', "Arquivo JSON de configuração não pode ser carregado:\n${e.getMessage()}")
                        error lib.status('E', 'Falha lendo/parseando arquivos JSON de configuração')
                    }

                    // Inicializa a variável que determina a criação do log da biblioteca
                    lib.log.create = jsonConf.createLog

                    echo 'Cria arquivo de log'
                    try {
                        lib.createLog(
                            action     : 'revert',
                            username   : lib.getBuildStarter(),
                            tag        : Tag,
                            buildNumber: env.BUILD_NUMBER,
                            jobName    : env.JOB_NAME,
                            workspace  : env.WORKSPACE
                        )
                    } catch (Exception e) {
                        //echo "Erro: ${e.getMessage()}"
                        echo lib.status('A', "Arquivo de log não pode ser criado:\n${e.getMessage()}")
                        lib.log.create = false
                    }

                    // Variável para armazenar o diretório raiz do repositório
                    diretorioRaiz = jsonConf.rootDirectories.revert

                    // Inicializa o nome dos scripts das ações
                    acao.matarSessoes.script      = jsonConf.scripts.killSessions
                    acao.listarInvalidos.script   = jsonConf.scripts.listInvalids
                    acao.recompilarObjetos.script = jsonConf.scripts.compileObjects

                    echo 'Início do Processo Concluído'
                } // script
            } // steps
        } // stage 'Inicia Processo'


        stage('Carrega JSONs') {
            steps {
                script {
                    echo lib.line('Início da Carga dos Arquivos JSON de Configuração e Planejamento')

                    // Nome dos arquivos
                    String dataFile = 'Config/Jenkins/DatabaseParam.json'
                    String planFile = "Config/Plannings/Planning_Revert.json"

                    texto = [
                        lib.text('Arquivos JSON'),
                        lib.text("Banco de Dados: ${dataFile}"),
                        lib.text("Planejamento do Revert: ${planFile}")
                    ]
                    echo lib.writeText(texto)

                    // Verifica se os arquivos JSON existem, se estão válidos e com dados
                    try {
                        jsonData = lib.parseJSON(dataFile, 'do banco de dados')
                        jsonPlan = lib.parseJSON(planFile, 'do planejamento para o revert')

                    //} catch (hudson.AbortException e) {
                    //    throw e
                    } catch (Exception e) {
                        //echo "Erro: ${e.getMessage()}"
                        echo lib.status('E', "Não foi possível ler/parsear os arquivos JSON:\n${e.getMessage()}")
                        error 'Falha lendo/parseando arquivos JSON'
                    }
                    echo lib.line('Final da Carga dos Arquivos JSON de Configuração e Planejamento')
                } // script
            } // steps
        } // stage 'Carrega JSONs'


        stage('Processa Parâmetros') {
            steps {
                script {
                    echo lib.line('Início do Processamento dos Parâmetros do Planejamento Para Revert')
                    String nomeDB
                    String usuario

                    // Valida a Tag selecionada com a Tag do planejamento
                    if (jsonPlan.tag != Tag) {
                        error lib.status('E', "Tag do planejamento ${jsonPlan.tag} é diferente da tag parametrizada ${Tag}")
                    }

                    if (Database == 'homolog') {
                        nomeDB = 'Homologação'
                    } else if (Database == 'prod') {
                        nomeDB = 'Produção'
                    }

                    // Descrição do build
                    usuario = jsonPlan.autor.trim().split()[0] // Primeiro nome do analista
                    currentBuild.description = "Tag: ${Tag} | Usr: ${usuario} | DB: ${nomeDB}"

                    texto = [
                        lib.text('Parâmetros de Execução do Build'),
                        lib.text("Tag: ${Tag}"),
                        lib.text("Database: ${nomeDB}"),
                        lib.text(''),
                        lib.text('Dados do Build'),
                        lib.text("Username: ${lib.getBuildStarter()}"),
                        lib.text("Job Name: ${env.JOB_NAME}"),
                        lib.text("Build #: ${env.BUILD_NUMBER}"),
                        lib.text("Workspace: ${env.WORKSPACE}")
                    ]
                    echo lib.writeText(texto)

                    // Dados do database
                    database.descricao   = jsonData[Database].descricao
                    database.enderecoIP  = jsonData[Database].enderecoIP
                    database.porta       = jsonData[Database].porta
                    database.serviceName = jsonData[Database].serviceName

                    database.conexao = "$DB_CONN_USR/$DB_CONN_PSW@${database.enderecoIP}:${database.porta}/${database.serviceName}"

                    // Mensagem de alerta para database de produção
                    if (Database == 'prod') {
                        texto = [
                            lib.text(''),
                            lib.text('------------------------------'),
                            lib.text('          ATENÇÃO             '),
                            lib.text('Revert no database de produção'),
                            lib.text('------------------------------'),
                            lib.text('')
                        ]
                        echo lib.writeText(texto)
                    }

                    // Ações planejadas
                    acao.matarSessoes.executar      = jsonPlan.acoes.matarSessoes
                    acao.listarInvalidos.executar   = jsonPlan.acoes.listarInvalidos
                    acao.recompilarObjetos.executar = jsonPlan.acoes.recompilarObjetos

                    texto = [
                        lib.text(''),
                        lib.text('Informações do Planejamento'),
                        lib.text("Autor: ${jsonPlan.autor}"),
                        lib.text("Data: ${jsonPlan.data}"),
                        lib.text("Descrição: ${jsonPlan.descricao}"),
                        lib.text("Tag: ${jsonPlan.tag}"),
                        lib.text(''),
                        lib.text('Ações Planejadas'),
                        lib.text("Matar sessões: ${jsonPlan.acoes.matarSessoes ? 'SIM' : 'NÃO'}"),
                        lib.text("Listar inválidos: ${jsonPlan.acoes.listarInvalidos ? 'SIM' : 'NÃO'}"),
                        lib.text("Recompilar objetos: ${jsonPlan.acoes.recompilarObjetos ? 'SIM' : 'NÃO'}"),
                        lib.text(''),
                        lib.text('Database'),
                        lib.text("Destino: ${database.descricao}"),
                        lib.text("Endereço IP: ${database.enderecoIP}"),
                        lib.text("Porta: ${database.porta}"),
                        lib.text("Service name: ${database.serviceName}"),
                        lib.text('')
                    ]
                    echo lib.writeText(texto)

                    // Verifica ações ativas
                    if (!jsonPlan.acoes.matarSessoes &&
                        !jsonPlan.acoes.listarInvalidos &&
                        !jsonPlan.acoes.recompilarObjetos) {
                        echo lib.status('A', 'Nenhuma ação adicional planejada')
                    }
                    echo lib.line('Final do Processamento dos Parâmetros do Planejamento Para Revert')
                } // script
            } // steps
        } // stage 'Processa Parâmetros'


        stage('Valida Objetos') {
            steps {
                script {
                    echo lib.line('Início da Validação dos Objetos Planejados Para Revert')
                    String comando
                    String retorno

                    jsonPlan.objetos.each { obj ->
                        lib.line("Verifica a existência do arquivo: ${diretorioRaiz}/${obj.nome}")
                        if (!fileExists(file: "${diretorioRaiz}/${obj.nome}")) {
                            error lib.status('E', "Arquivo ${diretorioRaiz}/${obj.nome} programado para deploy não encontrado")
                        }
                        echo lib.line("Arquivo: ${diretorioRaiz}/${obj.nome}")

                        lib.line('Verifica encoding do arquivo')
                        //comando = "uchardet ${diretorioRaiz}/${obj.nome}"
                        //retorno = sh(script: comando, returnStdout: true).trim().toUpperCase()

                        comando = "file -bi ${diretorioRaiz}/${obj.nome} | awk -F'charset=' '{print \$2}'"
                        retorno = sh(script: comando, returnStdout: true).trim().toUpperCase()

                        // ASCII é um subset do UTF-8 e apenas indica um arquivo sem acentos ou caracteres especias
                        if (retorno in ['US-ASCII', 'UTF-8']) {
                            echo lib.status('S', "Encoding válido: ${retorno}")
                        } else {
                            echo lib.status('E', "Encoding inválido: ${retorno}")
                            error lib.status('E', "Arquivo ${diretorioRaiz}/${obj.nome} programado para revert não está em US-ASCII UTF-8")
                        }
                    }
                    echo lib.line('Final da Validação dos Tipos de Arquivos Planejados Para Revert')
                } // script
            } // steps
        } // stage 'Valida Objetos'


        stage('Mata Sessões') {
            steps {
                script {
                    if (!acao.matarSessoes.executar) {
                        echo lib.status('A', 'Matar as sessões do banco de dados antes do revert está inativa no planejamento - nenhuma ação foi executada')
                        return
                    }
                    echo lib.status('A', 'Mata as Sessões do Banco de Dados Antes do Revert')
                    String script = acao.matarSessoes.script
                    String retorno

                    echo lib.line("Verificando script: ${script}")

                    if (!fileExists(file: script)) {
                        error lib.status('E', "Script ${script} para matar as sessões antes do revert não encontrado")
                    }

                    retorno = lib.runScript(script, database.conexao)
                    echo lib.line("Retorno da execução:\n${retorno}")

                    if (retorno.toUpperCase().contains('ERROR')) {
                        error lib.status('E', 'Script que mata as sessões do banco de dados antes do deploy está com erro')
                    } else if (!retorno.toUpperCase().contains('COMPLETED')) {
                        error lib.status('E', 'Script que mata as sessões do banco de dados antes do deploy não executou')
                    }

                    echo lib.line('Final do Script que Mata as Sessões do Banco de Dados Antes do Revert')
                } // script
            } // steps
        } // stage 'Mata Sessões'


        stage('Revert') {
            steps {
                script {
                    echo lib.line("Início do Revert dos Objetos Planejados no Banco ${database.descricao}")
                    String tipoObjeto
                    String retorno

                    jsonPlan.objetos.each { obj ->
                        tipoObjeto = obj.nome.split('/')[0][0..-2].toLowerCase()

                        texto = [
                            lib.text("Arquivo: ${diretorioRaiz}/${obj.nome}"),
                            lib.text("Descrição: ${obj.descricao}")
                        ]
                        echo lib.writeText(texto)

                        retorno = lib.runScript("${diretorioRaiz}/${obj.nome}", database.conexao, tipoObjeto)
                        echo lib.line("Retorno da execução:\n${retorno}")

                        retorno = retorno.toUpperCase()
                        switch (true) {
                            case retorno.contains('ERROR'):
                                error lib.status('E', "Erro aplicando ${obj.nome} - Revert abortado!")
                            case retorno.contains('CREATED'):
                                echo lib.status('S', "${obj.nome} criado")
                                break
                            case retorno.contains('ALTERED'):
                                echo lib.status('S', "${obj.nome} alterado")
                                break
                            case retorno.contains('COMPLETED'):
                                echo lib.status('S', "${obj.nome} executado")
                                break
                            default:
                                echo lib.status('S', 'Processo concluído')
                                break
                        }
                    }
                    echo lib.line("Final do Revert dos Objetos Planejados no Banco ${database.descricao}")
                } // script
            } // steps
        } // stage 'Revert'


        stage('Lista Inválidos') {
            steps {
                script {
                    if (!acao.listarInvalidos.executar) {
                        echo lib.status('A', 'Listagem de objetos inválidos após o revert está inativa no planejamento - nenhuma ação foi executada')
                        return
                    }
                    echo lib.line('Lista Objetos Inválidos Após o Revert')
                    String script = acao.listarInvalidos.script
                    String retorno

                    echo lib.line("Verificando script: ${script}")

                    if (!fileExists(file: script)) {
                        error lib.status('E', "Script ${script} para listar objetos inválidos após o revert não encontrado")
                    }

                    retorno = lib.runScript(script, database.conexao)
                    echo lib.line("Retorno da execução:\n${retorno}")

                    if (retorno.toUpperCase().contains('ERROR')) {
                        error lib.status('E', 'Script que lista objetos inválidos após o revert está com erro')
                    } else if (!retorno.toUpperCase().contains('COMPLETED')) {
                        error lib.status('E', 'Script que lista objetos inválidos após o revert não executou')
                    }

                    echo lib.line('Final do Script que Lista os Objetos Inválidos Após o Revert')
                } // script
            } // steps
        } // stage 'Lista Inválidos'


        stage('Recompila Objetos') {
            steps {
                script {
                    if (!acao.recompilarObjetos.executar) {
                        echo lib.status('A', 'Recompilação de objetos após o revert está inativa no planejamento - nenhuma ação foi executada')
                        return
                    }
                    echo lib.line('Recompila Objetos Após o Revert')
                    String script = acao.recompilarObjetos.script
                    String retorno

                    echo lib.line("Verificando script: ${script}")

                    if (!fileExists(file: script)) {
                        error lib.status('E', "Script ${script} para recompilar objetos inválidos após o revert não encontrado")
                    }

                    retorno = lib.runScript(script, database.conexao)
                    echo lib.line("Retorno da execução:\n${retorno}")

                    if (retorno.toUpperCase().contains('ERROR')) {
                        error lib.status('E', 'Script que recompila objetos após o revert está com erro')
                    } else if (!retorno.toUpperCase().contains('COMPLETED')) {
                        error lib.status('E', 'Script que recompila objetos após o revert não executou')
                    }

                    echo lib.line('Final do Script que Recompila os Objetos Após o Revert')
                } // script
            } // steps
        } // stage 'Recompila Objetos'

    } // stages


    post {
        always {
            script {
                if (lib.log.create) {
                    echo 'Finaliza o log e arquiva nos artefatos do build'
                    String status

                    if(currentBuild.result == 'SUCCESS') {
                        status = 'sucesso'
                    } else if(currentBuild.result == 'UNSTABLE') {
                        status = 'alerta'
                    } else {
                        status = 'erro'
                    }

                    // Verifica fisicamente se o arquivo foi criado no workspace
                    if (fileExists("${lib.log.path}/${lib.log.name}")) {
                        lib.flushLog()
                        lib.finishLog(
                            action     : 'Revert',
                            tag        : Tag,
                            buildNumber: env.BUILD_NUMBER,
                            status     : status
                        )
                        archiveArtifacts artifacts: "${lib.log.path}/${lib.log.name}", fingerprint: true, onlyIfSuccessful: false, allowEmptyArchive: true

                        echo "Log ${lib.log.name} do revert disponível nos artefatos do build"
                    } else {
                        echo "Falha no arquivamento do log do revert: O arquivo ${lib.log.name} não foi encontrado no Workspace"
                    }
                    // Limpa o nome do log após o arquivamento
                    lib.log.path = null
                    lib.log.name = null
                } else {
                    echo 'Arquivo de log do revert não foi criado'
                }
                echo 'Limpando o Workspace após o revert'
                cleanWs() // Limpa resíduos de builds antigos
            } // script
        } // always
    } // post

} // pipeline
