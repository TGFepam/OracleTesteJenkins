// Variável para o arquivo da biblioteca
def lib

// Variáveis para os objetos JSON
def jsonData // Informações dos bancos de dados
def jsonPlan // Planejamento do revert

// Variável para os dados do database
def database = [
    descricao  : '',
    enderecoIP : '',
    porta      : '',
    serviceName: '',
    conexao    : ''
]

// Variável com as ações configuradas no planejamento
def acao = [
    matarSessoes     : false,
    listarInvalidos  : false,
    recompilarObjetos: false
]

// Variável para display em bloco
def disp = []


pipeline {
    agent any
    environment {
        // Credencial de conexão com o banco de dados
        DB_CONN = credentials('DevOps_DB')
    }

    options {
        // Altera o funcionamento default e não faz o checkout do SCM no início do job
        skipDefaultCheckout(true)
    }

    stages {

        stage('Limpa Workspace') {
            steps {
                script {
                    echo 'Limpando Workspace antes do checkout'
                    cleanWs() // Limpa resíduos de builds antigos
                } //Script 
            } // Steps
        } // Stage 'Preparação'


        stage('Checkout Repositório') {
            steps {
                script {
                    echo 'Realizando Checkout do Repositório'

                    // Verifica se o parâmetro Tag foi selecionado
                    if (Tag == 'None') {
                        error 'É necessário selecionar uma Tag para o checkout do repositório e revert!'
                    }

                    echo "Realizando checkout da Tag: ${Tag}"
                    checkout scm: ([
                        $class: 'GitSCM',
                        branches: [[name: Tag]],
                        userRemoteConfigs: scm.userRemoteConfigs,
                        extensions: scm.extensions
                    ])
                    echo 'Checkout do Repositório Concluído'
                } // script
            } // Steps
        } // stage 'Checkout Repositório'


        stage('Inicia Processo') {
            steps {
                script {
                    echo 'Início do Processo'
                    // Carrega o arquivo da biblioteca
                    try {
                        lib = load 'Config/Jenkins/LibraryFile'
                    } catch (Exception e) {
                        // Erro crítico: mostra na hora e aborta
                        error "Falha carregando arquivo da biblioteca (Config/Jenkins/LibraryFile): ${e.getMessage()}"
                    }
                } // script
            } // steps
        } // stage 'Inicia Processo'


        stage('Carrega JSONs') {
            steps {
                script {
                    echo 'Início da Carga dos Arquivos JSON de Configuração e Planejamento'
                    // Nome dos arquivos
                    def dataFile = 'Config/Jenkins/DatabaseParam.json'
                    def planFile = "Config/Plannings/Planning_Revert.json"

                    disp = [
                        'Arquivos JSON',
                        "Banco de Dados: ${dataFile}",
                        "Planejamento do Revert: ${planFile}"
                    ]
                    echo disp.join('\n')

                    // Verifica se os arquivos JSON existem, se estão válidos e com dados
                    try {
                        jsonData = lib.processaJSON(dataFile, 'do banco de dados')
                        jsonPlan = lib.processaJSON(planFile, 'do planejamento para o revert')

                    } catch (hudson.AbortException e) {
                        throw e
                    } catch (Exception e) {
                        echo "Erro: ${e.getMessage()}"
                        error 'Falha lendo/parseando arquivos JSON'
                    }
                    echo 'Final da Carga dos Arquivos JSON de Configuração'
                } // script
            } // steps
        } // stage 'Carrega JSONs'


        stage('Processa Parâmetros') {
            steps {
                script {
                    echo 'Início do Processamento dos Parâmetros do Planejamento Para Revert'
                    def dbConfig
                    def usuario

                    disp = [
                        'Dados do Build',
                        "Username: ${lib.getBuildStarter()}",
                        "Job Name: ${env.JOB_NAME}",
                        "Build #: ${env.BUILD_NUMBER}",
                        "Workspace: ${env.WORKSPACE}"
                    ]
                    echo disp.join('\n')

                    // Dados do database
                    database.descricao   = jsonData[Database].descricao
                    database.enderecoIP  = jsonData[Database].enderecoIP
                    database.porta       = jsonData[Database].porta
                    database.serviceName = jsonData[Database].serviceName

                    database.conexao = "$DB_CONN_USR/$DB_CONN_PSW@${database.enderecoIP}:${database.porta}/${database.serviceName}"

                    // Mensagem de alerta para database de produção
                    if (Database == 'prod') {
                        disp = [
                            '------------------------------',
                            '          ATENÇÃO             ',
                            'Revert no database de produção',
                            '------------------------------'
                        ]
                        echo disp.join('\n')
                    }

                    // Ações planejadas
                    acao.matarSessoes      = jsonPlan.acoes.matarSessoes
                    acao.listarInvalidos   = jsonPlan.acoes.listarInvalidos
                    acao.recompilarObjetos = jsonPlan.acoes.recompilarObjetos

                    disp = [
                        '',
                        'Informações do Planejamento',
                        "Autor: ${jsonPlan.autor}",
                        "Data: ${jsonPlan.data}",
                        "Descrição: ${jsonPlan.descricao}",
                        '',

                        'Ações',
                        'Matar sessões: ' + jsonPlan.acoes.matarSessoes ? 'SIM' : 'NÃO',
                        'Listar inválidos: ' + jsonPlan.acoes.listarInvalidos ? 'SIM' : 'NÃO',
                        'Recompilar objetos: ' + jsonPlan.acoes.recompilarObjetos ? 'SIM' : 'NÃO',
                        '',

                        'Database',
                        "Destino: ${database.descricao}",
                        "Endereço IP: ${database.enderecoIP}",
                        "Porta: ${database.porta}",
                        "Service name: ${database.serviceName}",
                        ''
                    ]
                    echo disp.join('\n')

                    // Verifica ações ativas
                    if (!jsonPlan.acoes.matarSessoes &&
                        !jsonPlan.acoes.listarInvalidos &&
                        !jsonPlan.acoes.recompilarObjetos) {
                        echo 'Nenhuma ação adicional planejada'
                    }
                    echo 'Final do Processamento dos Parâmetros do Planejamento Para Revert'
                } // script
            } // steps
        } // stage 'Processa Parâmetros'


        stage('Valida Objetos') {
            steps {
                script {
                    echo 'Início da Validação dos Objetos Planejados Para Revert'
                    def diretorioRaiz = 'Revert'
                    def comando
                    def retorno

                    jsonPlan.objetos.each { obj ->
                        // Verifica a existência do arquivo
                        if (!fileExists(file: "${diretorioRaiz}/${obj.nome}")) {
                            error "Arquivo ${diretorioRaiz}/${obj.nome} programado para deploy não encontrado"
                        }
                        echo "Arquivo: ${diretorioRaiz}/${obj.nome}"

                        // Verifica encoding do arquivo
                        //comando = "uchardet ${script}"
                        //retorno = sh(script: comando, returnStdout: true).trim().toUpperCase()*/

                        comando = "file -bi ${diretorioRaiz}/${obj.nome} | awk -F'charset=' '{print \$2}'"
                        retorno = sh(script: comando, returnStdout: true).trim().toUpperCase()

                        // ASCII é um subset do UTF-8 e apenas indica um arquivo sem acentos ou caracteres especias
                        if (retorno in ['US-ASCII', 'UTF-8']) {
                            echo "Encoding válido: ${retorno}"
                        } else {
                            echo "Encoding inválido: ${retorno}"
                            error "Arquivo ${diretorioRaiz}/${obj.nome} programado para revert não está em UTF-8"
                        }
                    }
                    echo 'Final da Validação dos Tipos de Arquivos Planejados Para Revert'
                } // script
            } // steps
        } // stage 'Valida Objetos'


        stage('Mata Sessões') {
            steps {
                script {
                    if (!acao.matarSessoes) {
                        echo 'Matar as sessões do banco de dados antes do revert está inativa no planejamento - nenhuma ação foi executada'
                        return
                    }
                    echo 'Mata as Sessões do Banco de Dados Antes do Revert'
                    def script = 'Config/Scripts/KillSessions.sql'
                    def retorno

                    echo "Verificando script: ${script}"

                    if (!fileExists(file: script)) {
                        error "Script ${script} para matar as sessões antes do revert não encontrado"
                    }

                    retorno = lib.executaScript(script, database.conexao)
                    echo "Retorno da execução: ${retorno}"

                    if (retorno.toUpperCase().contains('ERROR')) {
                        error 'Script que mata as sessões do banco de dados antes do deploy está com erro'
                    } else if (!retorno.toUpperCase().contains('COMPLETED')) {
                        error 'Script que mata as sessões do banco de dados antes do deploy não executou'
                    }

                    echo 'Final do Script que Mata as Sessões do Banco de Dados Antes do Revert'
                } // script
            } // steps
        } // stage 'Mata Sessões'


        stage('Revert') {
            steps {
                script {
                    echo "Início do Revert dos Objetos Planejados no Banco ${database.descricao}"
                    def diretorioRaiz = 'Revert'
                    def comando
                    def retorno

                    jsonPlan.objetos.each { obj ->
                        disp = [
                            "Arquivo: ${diretorioRaiz}/${obj.nome}",
                            "Descrição: ${obj.descricao}"
                        ]
                        echo disp.join('\n')

                        retorno = lib.executaScript("${diretorioRaiz}/${obj.nome}", database.conexao)
                        echo "Retorno da execução: ${retorno}"

                        retorno = retorno.toUpperCase()
                        switch (true) {
                            case retorno.contains('ERROR'):
                                error "Erro aplicando ${obj.nome} - Revert abortado!"
                            case retorno.contains('CREATED'):
                                echo "${obj.nome} criado"
                                break
                            case retorno.contains('ALTERED'):
                                echo "${obj.nome} alterado"
                                break
                            case retorno.contains('COMPLETED'):
                                echo "${obj.nome} executado"
                                break
                            default:
                                echo 'Processo concluído'
                        }
                    }
                    echo "Final do Revert dos Objetos Planejados no Banco ${database.descricao}"
                } // script
            } // steps
        } // stage 'Revert'


        stage('Lista Inválidos') {
            steps {
                script {
                    if (!acao.listarInvalidos) {
                        echo 'Listagem de objetos inválidos após o revert está inativa no planejamento - nenhuma ação foi executada'
                        return
                    }
                    echo 'Lista Objetos Inválidos Após o Revert'
                    def script = 'Config/Scripts/CompileObjects.sql'
                    def retorno

                    echo "Verificando script: ${script}"

                    if (!fileExists(file: script)) {
                        error "Script ${script} para listar objetos inválidos após o revert não encontrado"
                    }

                    retorno = lib.executaScript(script, database.conexao)
                    echo "Retorno da execução: ${retorno}"

                    if (retorno.toUpperCase().contains('ERROR')) {
                        error 'Script que lista objetos inválidos após o revert está com erro'
                    } else if (!retorno.toUpperCase().contains('COMPLETED')) {
                        error 'Script que lista objetos inválidos após o revert não executou'
                    }

                    echo 'Final do Script que Lista os Objetos Inválidos Após o Revert'
                } // script
            } // steps
        } // stage 'Lista Inválidos'


        stage('Recompila Objetos') {
            steps {
                script {
                    if (!acao.recompilarObjetos) {
                        echo 'Recompilação de objetos após o revert está inativa no planejamento - nenhuma ação foi executada'
                        return
                    }
                    echo 'Recompila Objetos Após o Revert'
                    def script = 'Config/Scripts/CompileObjects.sql'
                    def retorno

                    echo "Verificando script: ${script}"

                    if (!fileExists(file: script)) {
                        error "Script ${script} para recompilar objetos inválidos após o revert não encontrado"
                    }

                    retorno = lib.executaScript(script, database.conexao)
                    echo "Retorno da execução: ${retorno}"

                    if (retorno.toUpperCase().contains('ERROR')) {
                        error 'Script que recompila objetos após o revert está com erro'
                    } else if (!retorno.toUpperCase().contains('COMPLETED')) {
                        error 'Script que recompila objetos após o revert não executou'
                    }

                    echo 'Final do Script que Recompila os Objetos Após o Revert'
                } // script
            } // steps
        } // stage 'Recompila Objetos'

    } // stages

} // pipeline
