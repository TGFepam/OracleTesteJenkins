/*--------------------------------------------------
    Adição de uma linha única ao buffer do log
--------------------------------------------------*/
def addLogLine(String line) {
    if (!log.create ||
        !log.handle ||
        !line) {
        return
    }

    // Adiciona a linha ao buffer
    def now = new Date().format('HH:mm:ss')
    log.buffer << "[${now}] ${line}"
}


/*--------------------------------------------------
    Inclusão de uma linha ao bloco de texto do log
--------------------------------------------------*/
def addLogTextLine(String line) {
    if (!log.create ||
        !log.handle ||
        !line) {
        return
    }

    // Adiciona a linha ao bloco de texto
    log.text << "    ${line}"
}


/*--------------------------------------------------
    Flush do bloco de texto ao buffer do log
--------------------------------------------------*/
def flushLogText() {
    if (!log.create ||
        !log.handle) {
        return
    }

    // Adiciona o bloco de texto ao buffer
    def now = new Date().format('HH:mm:ss')
    log.buffer << "[${now}]"
    log.text.each { line ->
        log.buffer << line
    }

    // Limpa o buffer após adicionar
    log.text.clear()
}


/*--------------------------------------------------
    Grava o conteúdo do buffer no arquivo de log e limpa o buffer
--------------------------------------------------*/
@NonCPS
def flushLog() {
    if (!log.create ||
        !log.handle ||
        !log.buffer) {
        return
    }

    // Descarrega o buffer
    log.handle.withWriterAppend('UTF-8') { writer -> // adiciona no arquivo
        writer.writeLine(log.buffer.join('\n'))
    }

    // Limpa o buffer após flush
    log.buffer.clear()
}


/*--------------------------------------------------
    Encerramento do arquivo de log
--------------------------------------------------*/
@NonCPS
def finishLog(Map args) {
    if (!log.create ||
        !log.handle) {
        return
    }

    // Extrai os parâmetros nomeados do Map.
    //def action      = args.action ?: 'deploy' // Para definir um valor padrão
    def action      = args.action
    def tag         = args.tag
    def buildNumber = args.buildNumber

    def timestamp = new Date().format('yyyyMMdd_HHmmss')

    // Prepara a finalização
    log.text = [
        '',
        '',
        '------------------------------',
        "${action} Terminado",
        "Tag    : ${tag}",
        "Build #: ${buildNumber}",
        "Data   : ${timestamp}",
        '------------------------------'
    ]

    // Descarrega o texto
    log.handle.withWriterAppend('UTF-8') { writer ->  // Acessa o arquivo
        writer.writeLine(log.text.join('\n')) // Adiciona a finalização
    }

    // Limpa o texto após a finalização
    log.text.clear()
}


