--------------------------------------------------*/
// Função que processa os arquivos JSONs
def processaJSON(String jsonFile, String descricao) {
    def disp = [
        linha('Blk', "Arquivo JSON ${descricao}", 'T')
    ]
    if (fileExists(file: jsonFile)) {
        disp << linha('Blk', 'Arquivo encontrado', 'T')
        def jsonParsed = readJSON file: jsonFile
        if (jsonParsed) {
            disp << linha('Blk', 'Arquivo parseado', 'T')
            echo texto(disp)
            return jsonParsed
        } else {
            disp << linha('Red', 'Arquivo inválido ou vazio', 'T')
            echo texto(disp)
            error "Arquivo JSON ${descricao} inválido ou vazio"
        }
    } else {
        disp << linha('Red', 'Arquivo não encontrado', 'T')
        echo texto(disp)
        error "Arquivo JSON ${descricao} não encontrado"
    }
}


/*--------------------------------------------------
    Validação de nomenclatura
--------------------------------------------------*/
// Função que valida o nome do branch e do tag
def consisteNome(String nome, String tipo) {
    if (tipo.toLowerCase() == 'branch') {
        if (consist.branchName) {
            return nome =~ regex.branch
        } else {
            return true
        }
    } else if (tipo.toLowerCase() == 'tag') {
        if (consist.tagName) {
            return nome =~ regex.tag
        } else {
            return true
        }
    }
    return false
}


/*--------------------------------------------------
