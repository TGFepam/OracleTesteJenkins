// Função de status
def status(String tipo = 'S', String mensagem = '') {
    if (!mensagem) {
        return
    }

    switch (tipo.toUpperCase()[0]) {
        case 'S':
            logLine("SUCESSO: ${mensagem}")
            return String.format(msg.sucesso, mensagem)
        case 'A':
            logLine("ALERTA: ${mensagem}")
            return String.format(msg.alerta, mensagem)
        case 'E':
            logLine("ERRO: ${mensagem}")
            return String.format(msg.erro, mensagem)
        default:
            echo String.format(msg.erro, "Tipo de status não previsto: ${tipo}")
            error "Tipo de status não previsto: ${tipo}"
    }
}

// Função de linhas
def linha(String cor = 'BLK', String mensagem = '', String tipo = 'L') {
    if (!mensagem) {
        return
    }

    cor = cor.toUpperCase()
    if (!cor in ['BLK', 'GRN', 'BLU', 'RED']) {
        echo String.format(msg.erro, "Cor da linha não prevista: ${cor}")
        error "Cor da linha não prevista: ${cor}"
    }

    if (tipo == 'L') {
        logLine(mensagem)
    } else if (tipo == 'T') {
        logTextLine(mensagem)
    } else {
        return
    }

    switch (cor) {
        case 'BLK':
            return String.format(msg.linhaBlk, mensagem)
        case 'GRN':
            return String.format(msg.linhaGrn, mensagem)
        case 'BLU':
            return String.format(msg.linhaBlu, mensagem)
        case 'RED':
            return String.format(msg.linhaRed, mensagem)
    }
}

// Função de labels
def label(String cor = 'BLK', String titulo = '', String mensagem = '', String tipo = 'L') {
    if (!mensagem) {
        return
    }

    def texto
    cor = cor.toUpperCase()
    if (!cor in ['BLK', 'GRN', 'BLU', 'RED']) {
        echo String.format(msg.erro, "Cor do label não prevista: ${cor}")
        error "Cor do label não prevista: ${cor}"
    }

    switch (mensagem) {
        case 'SIM_GRN':
            texto    = 'SIM'
            mensagem = msg.simGrn
            break
        case 'SIM_RED':
            texto    = 'SIM'
            mensagem = msg.simRed
            break
        case 'NAO_GRN':
            texto    = 'NAO'
            mensagem = msg.naoGrn
            break
        case 'NAO_RED':
            texto    = 'NAO'
            mensagem = msg.naoRed
            break
        default:
            texto = mensagem
    }

    if (tipo == 'L') {
        logLine("${titulo}: ${texto}")
    } else if (tipo == 'T') {
        logTextLine("${titulo}: ${texto}")
    } else {
        return
    }

    switch (cor) {
        case 'BLK':
            return String.format(msg.labelBlk, titulo, mensagem)
        case 'GRN':
            return String.format(msg.labelGrn, titulo, mensagem)
        case 'BLU':
            return String.format(msg.labelBlu, titulo, mensagem)
        case 'RED':
            return String.format(msg.labelRed, titulo, mensagem)
    }
}

