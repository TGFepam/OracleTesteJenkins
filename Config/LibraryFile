--------------------------------------------------*/
// Função que executa um script no SQL*Plus
def executaScript(String nome, String conexao, Boolean modo_Dry_Run = false) {
    if (modo_Dry_Run) {
        //echo lib.status('A', 'Deploy rodando em modo Dry-Run! Nenhuma alteração foi feita no banco de dados!')
        return 'Deploy em modo Dry-Run ativo!'
    }

    def comando = 'export LD_LIBRARY_PATH=/opt/oracle/instantclient_21_10\n' +
                    'export PATH=$LD_LIBRARY_PATH:$PATH\n' +
                    'export NLS_LANG=AMERICAN_AMERICA.WE8ISO8859P1\n' +
                    """echo "@${nome}" | sqlplus "${conexao}";\n"""
    def retorno = sh(script: comando, returnStdout: true)
    return retorno
}


