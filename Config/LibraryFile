// Função que cria o arquivo de log
@NonCPS
def createLog(String tarefa, String username, String jobName, String buildNumber, String workspace) {
    if (!log.create) {
        return
    }

    def timestamp = new Date().format('yyyyMMdd_HHmmss')
    log.name = "Config/Jenkins/Logs/${tarefa}__${timestamp}__${buildNumber}.log"
    log.file = new File("${workspace}/${log.name}")
    def path = log.file.getParentFile()

    // Cria diretório se não existir
    if (!path.isDirectory()) {
        path.mkdirs()
    }

    // Prepara o cabeçalho
    log.text = [
        '------------------------------',
        "Username: ${username}",
        "Job Name: ${jobName}",
        "Build #: ${buildNumber}",
        "WorkSpace: ${workspace}",
        "Data: ${timestamp}",
        '------------------------------',
        '',
        ''
    ]

    // Cria o arquivo e grava o cabeçalho
    log.file.withWriter('UTF-8') { writer -> // cria o arquivo
        writer.writeLine(log.text.join('\n'))
    }

    // Limpa o buffer após criar o cabeçalho
    log.text.clear()
}

// Função que adiciona uma linha ao buffer do log
def logLine(String line) {
    if (!log.create ||
        !log.file ||
        !line) {
        return
    }

    // Adiciona a linha ao buffer
    def now = new Date().format('HH:mm:ss')
    log.buffer << "[${now}] ${line}"
}

// Função que adiciona uma linha ao buffer de texto do log
def logTextLine(String line) {
    if (!log.create ||
        !log.file ||
        !line) {
        return
    }

    // Adiciona a linha ao buffer
    log.text << "  ${line}"
}

// Função que adiciona um texto ao buffer do log
def logText() {
    if (!log.create ||
        !log.file) {
        return
    }

    // Adiciona o texto ao buffer
    def now = new Date().format('HH:mm:ss')
    log.buffer << "[${now}]"
    log.text.each { line ->
        log.buffer << line
    }

    // Limpa o buffer após adicionar
    log.text.clear()
}

// Função que grava o conteúdo do buffer no arquivo e limpa o buffer
@NonCPS
def flushLog() {
    if (!log.create ||
        !log.file ||
        !log.buffer) {
        return
    }

    // Descarrega o buffer
    log.file.withWriterAppend('UTF-8') { writer -> // adiciona no arquivo
        writer.writeLine(log.buffer.join('\n'))
    }

    // Limpa o buffer após flush
    log.buffer.clear()
}

// Função que encerra o log
@NonCPS
def finishLog() {
    if (!log.create) {
        return
    }

    def timestamp = new Date().format('yyyyMMdd_HHmmss')

    // Prepara a finalização
    log.text = [
        '',
        '',
        '------------------------------',
        'Build Terminado',
        "Data: ${timestamp}",
        '------------------------------'
    ]

    // Descarrega o buffer
    log.file.withWriterAppend('UTF-8') { writer ->  // adiciona no arquivo
        writer.writeLine(log.text.join('\n'))
    }

    // Limpa o buffer após a finalização
    log.text.clear()
}


